<?xml version="1.0" encoding="utf-8"?>
<!-- Layout for a single university item in a standard list (used in Search and Explore) -->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    android:backgroundTint="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header: Displays the university initials badge and its overall rating -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Initials Badge: Circular background with short name code -->
            <TextView
                android:id="@+id/collegeInitials"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/circle_badge"
                android:gravity="center"
                android:text="TO"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#4B0082"
                android:layout_alignParentStart="true"/>

            <!-- Star Rating Section -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center">

                <TextView
                    android:text="★"
                    android:textSize="18sp"
                    android:textColor="#FFD700"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/collegeRating"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Main College Name -->
        <TextView
            android:id="@+id/collegeName"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2C2C2C"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <!-- Location display with a pin icon -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:text="📍"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/collegeCountry"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Annual Fees display with a currency icon -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="$"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#4B0082"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"/>

            <TextView
                android:id="@+id/collegeFees"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- University Type Badge (e.g. Public, Private) -->
        <TextView
            android:id="@+id/collegeType"
            android:textSize="12sp"
            android:textColor="#666666"
            android:background="@drawable/type_badge_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"/>

        <!-- Action Row: View Details button and Favorite/Bookmark button -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <!-- Button to open the CollegeDetailsActivity (Explicit Intent in Adapter) -->
            <Button
                android:id="@+id/viewDetailsBtn"
                android:text="View Details"
                android:textColor="#4B0082"
                android:backgroundTint="#E6E6FA"
                android:textSize="14sp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                app:cornerRadius="8dp"/>

            <!-- Toggle button for saving to favorites -->
            <ImageButton
                android:id="@+id/bookmarkBtn"
                android:src="@android:drawable/btn_star_big_off"
                android:background="@android:color/transparent"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerInside"
                android:contentDescription="Bookmark"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
