<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F2F8"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Let's Get Started"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#4B0082"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tell us what you're looking for to find your matches."
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_marginBottom="32dp"/>

        <!-- Section 1: Study -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📚 Your Education"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What do you want to study?"
                    android:textSize="12sp"
                    android:textColor="#4B0082"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                
                <AutoCompleteTextView
                    android:id="@+id/courseInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="e.g. Computer Science"
                    android:background="@drawable/type_badge_background"
                    android:padding="16dp"
                    android:textSize="15sp"
                    android:textColor="#333333"
                    android:layout_marginBottom="20dp"
                    android:completionThreshold="1"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preferred Degree Level"
                    android:textSize="12sp"
                    android:textColor="#4B0082"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/degreeLevelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/type_badge_background"
                    android:layout_marginBottom="20dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Section 2: Preferences -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌍 Location &amp; Budget"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ideal Region"
                    android:textSize="12sp"
                    android:textColor="#4B0082"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/locationSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/type_badge_background"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yearly Fee Budget"
                    android:textSize="12sp"
                    android:textColor="#4B0082"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/budgetSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/type_badge_background"
                    android:layout_marginBottom="20dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="University Type"
                    android:textSize="12sp"
                    android:textColor="#4B0082"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/universityTypeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/type_badge_background"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/submitBtn"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="FIND MY COLLEGES"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4B0082"
            android:layout_marginTop="32dp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:cornerRadius="16dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="60dp" />
    </LinearLayout>
</ScrollView>
