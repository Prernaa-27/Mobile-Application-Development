<?xml version="1.0" encoding="utf-8"?>
<!-- Home Fragment layout: Displays a list of all available universities -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#E6E6FA">

    <!-- Header: Page title and dynamic university count text -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp">

        <TextView
            android:text="Explore Universities"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#4B0082"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/universityCount"
            android:text="Showing all universities"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Main List Container: RecyclerView for university cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/universitiesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:clipToPadding="false" />
</LinearLayout>
