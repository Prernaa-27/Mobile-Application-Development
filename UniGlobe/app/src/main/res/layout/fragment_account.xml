<?xml version="1.0" encoding="utf-8"?>
<!-- Account Fragment layout: Displays user profile summary and preferences within the bottom navigation -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6E6FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Profile Card: User identification details -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- User Initial Avatar -->
                <TextView
                    android:id="@+id/profileInitials"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/circle_badge"
                    android:gravity="center"
                    android:text="U"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:textColor="#4B0082"
                    android:layout_marginBottom="16dp"/>

                <!-- Display Name -->
                <TextView
                    android:id="@+id/profileName"
                    android:text="User Name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#2C2C2C"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>

                <!-- Account Email -->
                <TextView
                    android:id="@+id/profileEmail"
                    android:text="user@email.com"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Preferences Card: Summary of questionnaire results -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="Your Preferences"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4B0082"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"/>

                <!-- List of saved preferences formatted in Java -->
                <TextView
                    android:id="@+id/preferencesText"
                    android:text="No preferences set"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:lineSpacingExtra="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"/>

                <!-- Edit button to relaunch the Questionnaire (Explicit Intent in Fragment) -->
                <Button
                    android:id="@+id/editPreferencesBtn"
                    android:text="Edit Preferences"
                    android:textColor="#4B0082"
                    android:backgroundTint="#E6E6FA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cornerRadius="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Logout Action: Triggers session end in AccountFragment.java -->
        <Button
            android:id="@+id/logoutBtn"
            android:text="Logout"
            android:textColor="#FFFFFF"
            android:backgroundTint="#9370DB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cornerRadius="8dp"/>
    </LinearLayout>
</ScrollView>
