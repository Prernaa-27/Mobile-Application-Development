<?xml version="1.0" encoding="utf-8"?>
<!-- scrollview so nothing gets cut off on smaller screens -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF0F5">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="40dp">
        <!-- screen heading -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Media Player App"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>
        <!-- pick a file from the device -->
        <Button
            android:id="@+id/btnOpenFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open File"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"/>
        <!-- for typing or pasting a direct video link -->
        <EditText
            android:id="@+id/etVideoUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter video URL"
            android:inputType="textUri"
            android:layout_marginBottom="16dp"/>
        <!-- loads whatever url is typed above -->
        <Button
            android:id="@+id/btnOpenUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open URL"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:layout_marginBottom="16dp"/>
        <!-- black bg so it doesn't look empty before anything loads -->
        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="20dp"
            android:background="#000000"/>
        <!-- playback controls -->
        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"/>
        <Button
            android:id="@+id/btnPause"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pause"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"/>
        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:layout_marginBottom="12dp"/>
        <!-- goes back to the beginning -->
        <Button
            android:id="@+id/btnRestart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restart"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"/>
    </LinearLayout>
</ScrollView>