<?xml version="1.0" encoding="utf-8"?>

<!-- Root scroll view so the layout works on smaller screens too -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="40dp">

        <!-- Screen title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:text="Currency Converter"
            android:textSize="24sp"
            android:textStyle="bold"
            android:fontFamily="@font/times" />

        <!-- User types the amount they want to convert here -->
        <EditText
            android:id="@+id/etAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter amount"
            android:inputType="numberDecimal"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/times" />

        <!-- Pick the currency you're converting FROM -->
        <Spinner
            android:id="@+id/spinnerFrom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Pick the currency you're converting TO -->
        <Spinner
            android:id="@+id/spinnerTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <!-- Triggers the conversion when tapped -->
        <Button
            android:id="@+id/btnConvert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Convert"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:fontFamily="@font/times" />

        <!-- Converted amount shows up here after the button is pressed -->
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result will appear here"
            android:textSize="18sp"
            android:padding="10dp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/times" />

        <!-- Opens the settings screen, probably for things like default currency -->
        <Button
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Open Settings"
            android:backgroundTint="#FF69B4"
            android:textColor="@android:color/white"
            android:fontFamily="@font/times" />

    </LinearLayout>
</ScrollView>